# App Settings
APP_NAME="QA Test Case Generator"
ENV="development"
HOST="0.0.0.0"
PORT=8000
LOG_LEVEL="INFO"

# Relational Database Settings
# For local SQLite development: sqlite:///./sql_app.db
# For Docker environment, use the same volume-mounted SQLite file.
DATABASE_URL="sqlite:///./sql_app.db"

# Document Database Settings (MongoDB)
# Local: mongodb://localhost:27017
# Docker: mongodb://mongodb:27017
MONGODB_URI="mongodb://mongodb:27017"
MONGODB_DB_NAME="qa_generator"

# LLM Providers Configuration
# Supported providers: "gemini", "openai", "mock"
LLM_PROVIDER="mock"
LLM_MODEL="gemini-1.5-flash"

# LLM API Keys
GEMINI_API_KEY="your-gemini-api-key-here"
OPENAI_API_KEY="your-openai-api-key-here"
